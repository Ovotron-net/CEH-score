# Database connection (resolved in order: DATABASE_PUBLIC_URL > DATABASE_URL > PG* vars)
DATABASE_URL=postgresql://user:password@localhost:5432/ceh_score
# DATABASE_PUBLIC_URL=
# PGUSER=
# PGPASSWORD=
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=ceh_score

# Supported public single-user browser UI mode. Production requires this exact
# combination. Every shared API read and write is unauthenticated in this mode.
ALLOW_OPEN_API=true
# API_SECRET must remain unset for the browser UI; never expose it through a
# NEXT_PUBLIC_* variable, page props, dehydrated query data, or client code.
# API_SECRET=
# API_SECRET mode is for API-only clients that can send an Authorization header.
# It is incompatible with the browser UI until page/session authentication exists.

# API requests use the same origin; cross-origin base URLs are not supported
# (server hydration reads the DB directly). CSP connect-src allows 'self' plus
# Vercel Speed Insights hosts (see next.config.ts).

# Client IP headers for rate limiting (x-real-ip / X-Forwarded-For) are only
# trusted when TRUST_PROXY_HEADERS=true, or when VERCEL=1 / RAILWAY_ENVIRONMENT
# is set (platform edges overwrite those headers). Otherwise IPs collapse to a
# shared "unknown" bucket. Set TRUST_PROXY_HEADERS=false to force that mode.
# TRUST_PROXY_HEADERS=
# TRUSTED_PROXY_DEPTH=1
